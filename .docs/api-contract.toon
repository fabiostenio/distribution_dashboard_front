╔══════════════════════════════════════════════════════════════════╗
║               API CONTRACT — GET /dashboard                      ║
╠══════════════════════════════════════════════════════════════════╣
║  URL     │ http://localhost:8080/dashboard                       ║
║  Método  │ GET                                                   ║
║  Auth    │ Nenhuma                                               ║
║  Polling │ 10 segundos                                           ║
╠══════════════════════════════════════════════════════════════════╣
║  RESPOSTA                                                        ║
║                                                                  ║
║  {                                                               ║
║    geradoEm: "ISO 8601"                                          ║
║                                                                  ║
║    resumo: {                                                     ║
║      totalTickets, abertos, emFila, finalizados,                 ║
║      totalAgentes, agentesDisponiveis, agentesOcupados           ║
║    }                                                             ║
║                                                                  ║
║    times: [{                                                     ║
║      time: CARTOES | EMPRESTIMOS | OUTROS                        ║
║      abertos, emFila, finalizados, totalAtendimentos             ║
║      agentes: [{                                                 ║
║        id, nome, atendimentosAtivos,                             ║
║        disponivel: bool, capacidadeMaxima                        ║
║      }]                                                          ║
║    }]                                                            ║
║                                                                  ║
║    fila: {                                                       ║
║      totalEmFila, ticketMaisAntigoEm (null se vazio)             ║
║      tempoEsperaMaximoMinutos (null se vazio)                    ║
║      tempoEsperaMedioMinutos                                     ║
║      porTime: [{ time, emFila, ticketMaisAntigoEm }]             ║
║    }                                                             ║
║  }                                                               ║
╚══════════════════════════════════════════════════════════════════╝
